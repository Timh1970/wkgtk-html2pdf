#!/usr/bin/make -f
include /usr/share/dpkg/default.mk

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_HOST_MULTIARCH ?= $(shell dpkg-architecture -qDEB_HOST_MULTIARCH)

# 1. Boilerplate
%:
	dh $@ --buildsystem=makefile

# 2. Dual Build Logic
override_dh_auto_build:
	# --- Build GTK3 / WK4 version ---
	$(MAKE) -C src/wk2gtkpdf clean
	$(MAKE) -C src/cli clean
	$(MAKE) -C src/wk2gtkpdf USE_WEBKIT_6=0
	$(MAKE) -C src/wk2gtkpdf install DESTDIR=$(CURDIR)/debian/tmp-wk4 PC_NAME=wk2gtkpdf-4.pc LIBDIR=/usr/lib/$(DEB_HOST_MULTIARCH)

	# Build WK4 CLI against the library we just put in src/wk2gtkpdf
	$(MAKE) -C src/cli \
		USER_INCDIR="-I$(CURDIR)/src/wk2gtkpdf" \
		USER_LIBDIR="-L$(CURDIR)/src/wk2gtkpdf" \
		LDLIBS="-L$(CURDIR)/src/wk2gtkpdf -lwk2gtkpdf $(shell pkg-config --libs libsystemd)"
	$(MAKE) -C src/cli install DESTDIR=$(CURDIR)/debian/tmp-wk4
	# RENAME THE WK4 BINARY
	mv $(CURDIR)/debian/tmp-wk4/usr/bin/wkgtk-html2pdf \
	   $(CURDIR)/debian/tmp-wk4/usr/bin/wkgtk-html2pdf-4


	# --- Build GTK4 / WK6 version ---
	$(MAKE) -C src/wk2gtkpdf clean
	$(MAKE) -C src/cli clean
	$(MAKE) -C src/wk2gtkpdf USE_WEBKIT_6=1
	$(MAKE) -C src/wk2gtkpdf install DESTDIR=$(CURDIR)/debian/tmp-wk6 PC_NAME=wk2gtkpdf-6.pc LIBDIR=/usr/lib/$(DEB_HOST_MULTIARCH)

	# Build WK6 CLI against the NEW library
	$(MAKE) -C src/cli \
		USER_INCDIR="-I$(CURDIR)/src/wk2gtkpdf" \
		USER_LIBDIR="-L$(CURDIR)/src/wk2gtkpdf" \
		LDLIBS="-L$(CURDIR)/src/wk2gtkpdf -lwk2gtkpdf $(shell pkg-config --libs libsystemd)"
	$(MAKE) -C src/cli install DESTDIR=$(CURDIR)/debian/tmp-wk6
	mv $(CURDIR)/debian/tmp-wk6/usr/bin/wkgtk-html2pdf \
	   $(CURDIR)/debian/tmp-wk6/usr/bin/wkgtk-html2pdf-6

# 3. Installation & Sorting
override_dh_auto_install:
	# We skip the default auto_install because we did it manually in the build step above
	:

override_dh_install:
	# 1. Install Engine 4 (.so only)
	dh_install -plibwk2gtkpdf4-0 --sourcedir=debian/tmp-wk4 usr/lib/*/libwk2gtkpdf.so.*

	# 2. Install Engine 6 (.so only)
	dh_install -plibwk2gtkpdf6-0 --sourcedir=debian/tmp-wk6 usr/lib/*/libwk2gtkpdf.so.*

	# 3. Install the -dev package (Headers and BOTH .pc files)
	# Copy the wk4 .pc file to a versioned name first
	cp debian/tmp-wk4/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/wk2gtkpdf.pc \
	   debian/tmp-wk4/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/wk2gtkpdf-4.pc
	# Copy the wk6 .pc file to a versioned name
	cp debian/tmp-wk6/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/wk2gtkpdf.pc \
	   debian/tmp-wk6/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig/wk2gtkpdf-6.pc

	dh_install -plibwk2gtkpdf-dev --sourcedir=debian/tmp-wk6 usr/include/*
	dh_install -plibwk2gtkpdf-dev --sourcedir=debian/tmp-wk6 usr/lib/*/libwk2gtkpdf.so
	# Install both versioned .pc files
	dh_install -plibwk2gtkpdf-dev --sourcedir=debian/tmp-wk4 usr/lib/*/pkgconfig/wk2gtkpdf-4.pc
	dh_install -plibwk2gtkpdf-dev --sourcedir=debian/tmp-wk6 usr/lib/*/pkgconfig/wk2gtkpdf-6.pc
	# And keep the default wk2gtkpdf.pc from the WK6 build
	dh_install -plibwk2gtkpdf-dev --sourcedir=debian/tmp-wk6 usr/lib/*/pkgconfig/wk2gtkpdf.pc

	# 4. Assets and CLI (Standard WK6 build)
	dh_install -pwkgtk-html2pdf-common --sourcedir=debian/tmp-wk6 usr/share/*
	dh_install -pwkgtk-html2pdf --sourcedir=debian/tmp-wk6 usr/bin/*


override_dh_installsystemd:
	# Point the service to the COMMON package
	dh_installsystemd -pwkgtk-html2pdf-common --name=xvfb

override_dh_shlibdeps:
	# Check dependencies against both local build folders
	dh_shlibdeps -l$(CURDIR)/debian/tmp-wk4/usr/lib/$(DEB_HOST_MULTIARCH):$(CURDIR)/debian/tmp-wk6/usr/lib/$(DEB_HOST_MULTIARCH)
