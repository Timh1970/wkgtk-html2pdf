prefix=/usr
exec_prefix=${prefix}
libdir=@LIBDIR@
includedir=${prefix}/include

Name: wk2gtkpdf
Description: Professional WebKit-based HTML to PDF rendering library
Version: @VERSION@
Conflicts:
Libs: -L${libdir} -lwk2gtkpdf@ENGINE_SUFFIX@
Cflags: -I${includedir}
Requires.private: @WEBKIT_PC_NAME@ libpodofo json-c
