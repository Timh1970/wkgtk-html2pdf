prefix=/usr
exec_prefix=${prefix}
libdir=@LIBDIR@
includedir=${prefix}/include

Name: wk2gtkpdf
Description: wk2gtkpdf is a library for creating portable document format (pdf) files from html.
Version: 0.0.28
Conflicts:
Libs: -L${libdir} -lwk2gtkpdf
Cflags: -I${includedir}
Requires.private: @WEBKIT_PC_NAME@ libpodofo json-c
